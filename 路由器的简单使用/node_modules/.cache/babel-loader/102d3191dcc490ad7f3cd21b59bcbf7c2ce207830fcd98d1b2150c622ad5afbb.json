{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: 'TodoFooter',\n  props: ['things', 'Allck', ' Allclear'],\n  computed: {\n    DoneTotal() {\n      let i = 0;\n      this.things.forEach(element => {\n        if (element.done) {\n          i++;\n        }\n      });\n      return i;\n    },\n    All() {\n      return this.things.length === this.DoneTotall && this.things.length > 0;\n    }\n  },\n  methods: {\n    checkAll(e) {\n      console.log(e.target.checked);\n      this.Allck(e.target.checked);\n    },\n    claerAll() {\n      Allclear();\n    }\n  }\n};","map":{"version":3,"names":["name","props","computed","DoneTotal","i","things","forEach","element","done","All","length","DoneTotall","methods","checkAll","e","console","log","target","checked","Allck","claerAll","Allclear"],"sources":["src/components/TodoFooter.vue"],"sourcesContent":["<template>\r\n    <div class=\"todo-footer\" v-show=\"things.length\">\r\n        <label>\r\n          <input type=\"checkbox\" :check=\"All\" @click=\"checkAll\" >\r\n        </label>\r\n        <span>\r\n          <span>已完成{{DoneTotal}}</span> / 全部{{things.length}}\r\n        </span>\r\n        <button class=\"btn btn-danger\" @click=\"clearAll\">清除已完成任务</button>\r\n      </div>\r\n</template>\r\n<script>\r\n\r\nexport default {\r\n    name:'TodoFooter',\r\n    props:['things','Allck',' Allclear'],\r\n    computed:{\r\n      DoneTotal(){\r\n        let i=0\r\n      this.things.forEach(element => {\r\n         if(element.done)\r\n         {\r\n          i++\r\n         }\r\n      })\r\n      return i\r\n      },\r\n      All(){\r\n        return this.things.length===this.DoneTotall && this.things.length>0\r\n      }\r\n    },\r\n    methods:{\r\n      checkAll(e){\r\n        console.log(e.target.checked)\r\n        this.Allck(e.target.checked)\r\n      },\r\n      claerAll(){\r\n        Allclear()\r\n      }\r\n    }\r\n}\r\n</script>\r\n<style scoped>\r\n/*footer*/\r\n.todo-footer {\r\n  height: 40px;\r\n  line-height: 40px;\r\n  padding-left: 6px;\r\n  margin-top: 5px;\r\n}\r\n\r\n.todo-footer label {\r\n  display: inline-block;\r\n  margin-right: 20px;\r\n  cursor: pointer;\r\n}\r\n\r\n.todo-footer label input {\r\n  position: relative;\r\n  top: -1px;\r\n  vertical-align: middle;\r\n  margin-right: 5px;\r\n}\r\n\r\n.todo-footer button {\r\n  float: right;\r\n  margin-top: 5px;\r\n}\r\n</style>"],"mappings":";;AAaA;EACAA,IAAA;EACAC,KAAA;EACAC,QAAA;IACAC,UAAA;MACA,IAAAC,CAAA;MACA,KAAAC,MAAA,CAAAC,OAAA,CAAAC,OAAA;QACA,IAAAA,OAAA,CAAAC,IAAA,EACA;UACAJ,CAAA;QACA;MACA;MACA,OAAAA,CAAA;IACA;IACAK,IAAA;MACA,YAAAJ,MAAA,CAAAK,MAAA,UAAAC,UAAA,SAAAN,MAAA,CAAAK,MAAA;IACA;EACA;EACAE,OAAA;IACAC,SAAAC,CAAA;MACAC,OAAA,CAAAC,GAAA,CAAAF,CAAA,CAAAG,MAAA,CAAAC,OAAA;MACA,KAAAC,KAAA,CAAAL,CAAA,CAAAG,MAAA,CAAAC,OAAA;IACA;IACAE,SAAA;MACAC,QAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}