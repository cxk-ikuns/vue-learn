{"ast":null,"code":"import pubsub from 'pubsub-js';\nexport default {\n  name: 'TodoItem',\n  data() {\n    return {\n      is_show: true\n    };\n  },\n  props: ['todoobj'],\n  methods: {\n    changedone(id) {\n      // this.$bus.$emit('checkdone',id)\n      pubsub.publish('checkdone', id);\n    },\n    ButtonDelete(id) {\n      if (confirm(\"确认删除吗\")) {\n        //  this.$bus.$emit('btdelete',id)\n        pubsub.publish('deletedone', id);\n      }\n    },\n    ButtonEdit(todoobj) {\n      this.$set(todoobj, 'isEdit', true);\n      this.$nextTick(function () {\n        this.$refs.inputcontent.focus();\n      });\n    },\n    isOk(todoobj, e) {\n      todoobj.isEdit = false;\n      if (!e.target.value.trim()) {\n        return alert('内容不能为空');\n      }\n      this.$bus.$emit('updatethings', todoobj.id, e.target.value);\n    }\n  }\n};","map":{"version":3,"names":["pubsub","name","data","is_show","props","methods","changedone","id","publish","ButtonDelete","confirm","ButtonEdit","todoobj","$set","$nextTick","$refs","inputcontent","focus","isOk","e","isEdit","target","value","trim","alert","$bus","$emit"],"sources":["src/components/TodoItem.vue"],"sourcesContent":["<template>\r\n    <li>\r\n          <label>\r\n            <input type=\"checkbox\" :checked=\"todoobj.done\" @click=\"changedone(todoobj.id)\">\r\n            <span v-show=\"!todoobj.isEdit\" v-if=\"is_show\">{{todoobj.thing}}</span>\r\n            <input type=\"text\" v-show=\"todoobj.isEdit\" \r\n                              :value=\"todoobj.thing\" \r\n                              @blur=\"isOk(todoobj,$event)\"\r\n                              ref=\"inputcontent\"\r\n                              \r\n            >\r\n          </label>\r\n          <button class=\"btn btn-danger\" @click=\"ButtonDelete(todoobj.id)\">删除</button>\r\n          <button class=\"btn btn-danger\" @click=\"ButtonEdit(todoobj)\" >编辑</button>\r\n          <button class=\"btn btn-danger\" @click=\"\" >显示/隐藏</button>\r\n    </li>\r\n</template>\r\n<script>\r\nimport pubsub from 'pubsub-js'\r\nexport default {\r\n    name:'TodoItem',\r\n    data(){\r\n        return {is_show:true}\r\n    },\r\n    props:['todoobj'],\r\n    methods:{\r\n      changedone(id){\r\n        // this.$bus.$emit('checkdone',id)\r\n        pubsub.publish('checkdone',id)\r\n      },\r\n      ButtonDelete(id){\r\n      \r\n       if(confirm(\"确认删除吗\"))\r\n       {\r\n        //  this.$bus.$emit('btdelete',id)\r\n        pubsub.publish('deletedone',id)\r\n       }\r\n      },\r\n      ButtonEdit(todoobj){\r\n        this.$set(todoobj,'isEdit',true)\r\n        this.$nextTick(function(){\r\n          this.$refs.inputcontent.focus()\r\n        })\r\n      },\r\n      isOk(todoobj,e){\r\n        todoobj.isEdit=false\r\n        if(!e.target.value.trim())\r\n        {\r\n          return alert('内容不能为空')\r\n        }\r\n        this.$bus.$emit('updatethings',todoobj.id,e.target.value)\r\n      }\r\n    }\r\n}\r\n</script>\r\n<style>\r\n/*item*/\r\nli {\r\n  list-style: none;\r\n  height: 36px;\r\n  line-height: 36px;\r\n  padding: 0 5px;\r\n  border-bottom: 1px solid #ddd;\r\n}\r\n\r\nli label {\r\n  float: left;\r\n  cursor: pointer;\r\n}\r\n\r\nli label li input {\r\n  vertical-align: middle;\r\n  margin-right: 6px;\r\n  position: relative;\r\n  top: -1px;\r\n}\r\n\r\nli button {\r\n  display: block;\r\n  float: right;\r\n  \r\n  margin-top: 3px;\r\n}\r\n\r\nli:before {\r\n  content: initial;\r\n}\r\n\r\nli:last-child {\r\n  border-bottom: none;\r\n}\r\nli:hover{\r\n  background-color: #ddd;\r\n}\r\n\r\n</style>"],"mappings":"AAkBA,OAAAA,MAAA;AACA;EACAC,IAAA;EACAC,KAAA;IACA;MAAAC,OAAA;IAAA;EACA;EACAC,KAAA;EACAC,OAAA;IACAC,WAAAC,EAAA;MACA;MACAP,MAAA,CAAAQ,OAAA,cAAAD,EAAA;IACA;IACAE,aAAAF,EAAA;MAEA,IAAAG,OAAA,WACA;QACA;QACAV,MAAA,CAAAQ,OAAA,eAAAD,EAAA;MACA;IACA;IACAI,WAAAC,OAAA;MACA,KAAAC,IAAA,CAAAD,OAAA;MACA,KAAAE,SAAA;QACA,KAAAC,KAAA,CAAAC,YAAA,CAAAC,KAAA;MACA;IACA;IACAC,KAAAN,OAAA,EAAAO,CAAA;MACAP,OAAA,CAAAQ,MAAA;MACA,KAAAD,CAAA,CAAAE,MAAA,CAAAC,KAAA,CAAAC,IAAA,IACA;QACA,OAAAC,KAAA;MACA;MACA,KAAAC,IAAA,CAAAC,KAAA,iBAAAd,OAAA,CAAAL,EAAA,EAAAY,CAAA,CAAAE,MAAA,CAAAC,KAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}