{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport \"core-js/modules/es.json.parse.js\";\nimport \"core-js/modules/es.json.stringify.js\";\nimport TodoHeader from './components/TodoHeader.vue';\nimport TodoList from './components/TodoList.vue';\nimport TodoFooter from './components/TodoFooter.vue';\nexport default {\n  name: 'App',\n  components: {\n    TodoHeader,\n    TodoList,\n    TodoFooter\n  },\n  data() {\n    return {\n      things: JSON.parse(localStorage.getItem('things')) || []\n    };\n  },\n  methods: {\n    addcontent(content) {\n      this.things.unshift(content);\n    },\n    checkdone(id) {\n      this.things.forEach(p => {\n        if (p.id === id) {\n          p.done = !p.done;\n        }\n      });\n    },\n    btdelete(id) {\n      this.things = this.things.filter(p => {\n        return p.id !== id;\n      });\n    },\n    Allck(content) {\n      if (content === true) {\n        this.things.forEach(p => {\n          if (p.done === false) {\n            p.done = !p.done;\n          }\n        });\n      } else {\n        this.things.forEach(p => {\n          p.done = !p.done;\n        });\n      }\n    },\n    allclear() {\n      this.things = this.things.filter(p => {\n        return !p.done;\n      });\n    }\n  },\n  watch: {\n    things: {\n      deep: true,\n      handler(new_things) {\n        return JSON.stringify(localStorage.setItem('things', 'new_things'));\n      }\n    }\n  }\n};","map":{"version":3,"names":["TodoHeader","TodoList","TodoFooter","name","components","data","things","JSON","parse","localStorage","getItem","methods","addcontent","content","unshift","checkdone","id","forEach","p","done","btdelete","filter","Allck","allclear","watch","deep","handler","new_things","stringify","setItem"],"sources":["src/App.vue"],"sourcesContent":["<template>\r\n   <div id=\"root\">\r\n    <div class=\"todo-container\">\r\n            <div class=\"todo-wrap\">\r\n            <TodoHeader :addcontent=\"addcontent\"></TodoHeader>\r\n            <TodoList :things=\"things\" :checkdone=\"checkdone\" :btdelete=\"btdelete\"></TodoList>\r\n            <TodoFooter :things=\"things\" :Allck=\"Allck\" :allclear=\"allclear\"></TodoFooter>\r\n            </div>\r\n   </div>\r\n</div>\r\n</template>\r\n<script>\r\n\r\nimport TodoHeader from './components/TodoHeader.vue'\r\nimport TodoList from './components/TodoList.vue'\r\nimport TodoFooter from './components/TodoFooter.vue'\r\nexport default {\r\n    name:'App',\r\n     components:{TodoHeader,TodoList,TodoFooter},\r\n     data(){\r\n      return {\r\n        things:JSON.parse(localStorage.getItem('things')) || []\r\n      }\r\n    },\r\n    methods:{\r\n      addcontent(content){\r\n         this.things.unshift(content)\r\n      },\r\n      checkdone(id){\r\n          this.things.forEach((p)=>{\r\n            if(p.id===id)\r\n            {\r\n              p.done=!p.done\r\n            }\r\n          })\r\n      },\r\n      btdelete(id){\r\n        this.things=this.things.filter((p)=>{\r\n          return p.id!==id\r\n        })\r\n      },\r\n      Allck(content){\r\n          if(content===true)\r\n          {\r\n            this.things.forEach((p)=>{\r\n              if(p.done===false)\r\n              {\r\n                p.done=!p.done\r\n              }\r\n            })\r\n          }\r\n          else\r\n          {\r\n            this.things.forEach((p)=>{\r\n              p.done=!p.done\r\n            })\r\n          }\r\n      },\r\n      allclear(){\r\n        this.things=this.things.filter((p)=>{\r\n          return !p.done\r\n        })\r\n      }\r\n    },\r\n    watch:{\r\n      things:{\r\n        deep:true,\r\n        handler(new_things){\r\n          return JSON.stringify(localStorage.setItem('things','new_things'))\r\n        }\r\n      }\r\n    }\r\n}\r\n</script>\r\n<style >\r\n/*base*/\r\nbody {\r\n  backgrou