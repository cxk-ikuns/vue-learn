{"ast":null,"code":"import pubsub from 'pubsub-js';\nexport default {\n  name: 'TodoItem',\n  props: ['todoobj'],\n  methods: {\n    changedone(id) {\n      // this.$bus.$emit('checkdone',id)\n      pubsub.publish('checkdone', id);\n    },\n    ButtonDelete(id) {\n      if (confirm(\"确认删除吗\")) {\n        //  this.$bus.$emit('btdelete',id)\n        pubsub.publish('deletedone', id);\n      }\n    },\n    ButtonEdit(todoobj) {\n      this.$set(todoobj, 'isEdit', true);\n    },\n    isOk(todoobj) {\n      todoobj.isEdit = false;\n    }\n  }\n};","map":{"version":3,"names":["pubsub","name","props","methods","changedone","id","publish","ButtonDelete","confirm","ButtonEdit","todoobj","$set","isOk","isEdit"],"sources":["src/components/TodoItem.vue"],"sourcesContent":["<template>\r\n    <li>\r\n          <label>\r\n            <input type=\"checkbox\" :checked=\"todoobj.done\" @click=\"changedone(todoobj.id)\">\r\n            <span v-show=\"!todoobj.isEdit\">{{todoobj.thing}}</span>\r\n            <input type=\"text\" name=\"\" id=\"\" v-show=\"todoobj.isEdit\" :value=\"todoobj.thing\" @blur=\"isOk(todoobj)\">\r\n          </label>\r\n          <button class=\"btn btn-danger\" @click=\"ButtonDelete(todoobj.id)\">删除</button>\r\n          <button class=\"btn btn-danger\" @click=\"ButtonEdit(todoobj)\">编辑</button>\r\n    </li>\r\n</template>\r\n<script>\r\nimport pubsub from 'pubsub-js'\r\nexport default {\r\n    name:'TodoItem',\r\n    props:['todoobj'],\r\n    methods:{\r\n      changedone(id){\r\n        // this.$bus.$emit('checkdone',id)\r\n        pubsub.publish('checkdone',id)\r\n      },\r\n      ButtonDelete(id){\r\n      \r\n       if(confirm(\"确认删除吗\"))\r\n       {\r\n        //  this.$bus.$emit('btdelete',id)\r\n        pubsub.publish('deletedone',id)\r\n       }\r\n      },\r\n      ButtonEdit(todoobj){\r\n        this.$set(todoobj,'isEdit',true)\r\n      },\r\n      isOk(todoobj){\r\n        todoobj.isEdit=false\r\n      }\r\n    }\r\n}\r\n</script>\r\n<style>\r\n/*item*/\r\nli {\r\n  list-style: none;\r\n  height: 36px;\r\n  line-height: 36px;\r\n  padding: 0 5px;\r\n  border-bottom: 1px solid #ddd;\r\n}\r\n\r\nli label {\r\n  float: left;\r\n  cursor: pointer;\r\n}\r\n\r\nli label li input {\r\n  vertical-align: middle;\r\n  margin-right: 6px;\r\n  position: relative;\r\n  top: -1px;\r\n}\r\n\r\nli button {\r\n  display: block;\r\n  float: right;\r\n  \r\n  margin-top: 3px;\r\n}\r\n\r\nli:before {\r\n  content: initial;\r\n}\r\n\r\nli:last-child {\r\n  border-bottom: none;\r\n}\r\nli:hover{\r\n  background-color: #ddd;\r\n}\r\n\r\n</style>"],"mappings":"AAYA,OAAAA,MAAA;AACA;EACAC,IAAA;EACAC,KAAA;EACAC,OAAA;IACAC,WAAAC,EAAA;MACA;MACAL,MAAA,CAAAM,OAAA,cAAAD,EAAA;IACA;IACAE,aAAAF,EAAA;MAEA,IAAAG,OAAA,WACA;QACA;QACAR,MAAA,CAAAM,OAAA,eAAAD,EAAA;MACA;IACA;IACAI,WAAAC,OAAA;MACA,KAAAC,IAAA,CAAAD,OAAA;IACA;IACAE,KAAAF,OAAA;MACAA,OAAA,CAAAG,MAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}